# Required
MOONSHOT_API_KEY=moonshot api key here

# Optional — unlocks richer web search results (get free key at https://serpapi.com)
# SERPAPI_KEY=serpapi key here

# Optional — reasoning effort for Kimi K3 (none/minimal/low/medium/high/xhigh/max).
# Default is "max". Set to "off" to omit the parameter entirely if the endpoint rejects it.
# KIMI_REASONING_EFFORT=max

# Optional — privacy mode. "1" disables ALL third-party web search calls
# (DuckDuckGo/Bing/Yahoo/Brave/SerpAPI). No price can be sourced or verified in
# this mode, so the report is empty of price data by design. Same as --offline.
# GROCERY_OFFLINE=1
